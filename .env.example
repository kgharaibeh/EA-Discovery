# MongoDB
MONGODB_URI=mongodb://mongo:27017/ea_discovery
MONGODB_DATABASE=ea_discovery

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production

# Credential Management
CREDENTIAL_BACKEND=encrypted_file
CREDENTIAL_MASTER_KEY=change-me-32-byte-key-for-aes256

# HashiCorp Vault (if CREDENTIAL_BACKEND=vault)
VAULT_URL=http://vault:8200
VAULT_TOKEN=

# LLM Provider (claude, openai, ollama)
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://ollama:11434

# Scanning
SCAN_CONCURRENCY=10
SCAN_TIMEOUT=300
SSH_DEFAULT_PORT=22
WINRM_DEFAULT_PORT=5985

# LDAP/AD (optional)
LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
